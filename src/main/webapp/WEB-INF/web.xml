<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>
    <servlet>
        <servlet-name>register</servlet-name>
        <servlet-class>controllers.register</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>controllers.login</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>controllers.logout</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>upload</servlet-name>
        <servlet-class>controllers.upload</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>home</servlet-name>
        <servlet-class>controllers.home</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>serve</servlet-name>
        <servlet-class>controllers.serve</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>discussion</servlet-name>
        <servlet-class>controllers.discussion</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>postAnswer</servlet-name>
        <servlet-class>controllers.postAnswer</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>markAccepted</servlet-name>
        <servlet-class>controllers.markAccepted</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>adminLogin</servlet-name>
        <servlet-class>controllers.adminLogin</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>adminDashboard</servlet-name>
        <servlet-class>controllers.adminDashboard</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>adminLogout</servlet-name>
        <servlet-class>controllers.adminLogout</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>banUser</servlet-name>
        <servlet-class>controllers.banUser</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>bannedList</servlet-name>
        <servlet-class>controllers.bannedList</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>unbanUser</servlet-name>
        <servlet-class>controllers.unbanUser</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>deleteUser</servlet-name>
        <servlet-class>controllers.deleteUser</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>register</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>upload</servlet-name>
        <url-pattern>/upload</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>home</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>serve</servlet-name>
        <url-pattern>/serve/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>discussion</servlet-name>
        <url-pattern>/discussion/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>postAnswer</servlet-name>
        <url-pattern>/postAnswer</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>markAccepted</servlet-name>
        <url-pattern>/markAccepted</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>adminLogin</servlet-name>
        <url-pattern>/adminLogin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>adminDashboard</servlet-name>
        <url-pattern>/adminDashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>adminLogout</servlet-name>
        <url-pattern>/adminLogout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>banUser</servlet-name>
        <url-pattern>/banUser/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>bannedList</servlet-name>
        <url-pattern>/bannedList</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>unbanUser</servlet-name>
        <url-pattern>/unbanUser/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>deleteUser</servlet-name>
        <url-pattern>/deleteUser/*</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
